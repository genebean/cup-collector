# Dev service data (local containers)
pocketbase/pb_data/
pocketid/

# Claude Code personal settings (permissions, MCP config) — not for public repos
.claude/
!.claude/skills/
!.claude/skills/**
.mcp.json

# Claude Code auto-memory (belongs in ~/.claude/projects/..., never in the repo)
memory/

# Next.js
app/.next/
app/node_modules/
app/.env.local
app/.env.prod
app/next-env.d.ts
app/tsconfig.tsbuildinfo
app/public/sw.js
app/public/workbox-*.js
app/public/worker-*.js

# Test output (kept outside app/ so Turbopack doesn't watch it)
coverage/
app/test-results/

# Playwright artifacts
.playwright-mcp/
screenshot-*.png
app/playwright/.auth/
app/playwright-report/
app/test-results/playwright/

# Test data
test-cups.csv

# Nix
result
cups.csv

# Scraper cache (populated with --cache-dir; not for version control)
.scrape-cache/

# Downloaded geo boundary data (fetched on first run by backfill-region)
scripts/data/*.geojson

# Dev stack log files (written by cc-dev-stack; read by agents and tail)
.dev-logs/

# Next.js prerender cache (dev; production uses /var/cache/cup-collector via systemd)
.next-cache/
