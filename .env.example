# Cup Collector — Environment Variables
# Copy this file to .env.local for local development.
# In production, pass via the NixOS module's envFile option (managed by sops-nix).
# See docs/setup/deployment.html and docs/reference/spec.html §04 for full details.

# ── PocketID OIDC ──────────────────────────────────────────────────────────────
# Your self-hosted PocketID instance URL (no trailing slash)
# Production: set via services.cupCollector.pocketidIssuerUrl in the NixOS module
POCKETID_ISSUER_URL=https://id.yourdomain.com

# From the PocketID admin panel → Applications → Cup Collector
POCKETID_CLIENT_ID=cup-collector
POCKETID_CLIENT_SECRET=from-pocketid-registration

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-generated-secret

# Full public URL of this app (no trailing slash)
# Production: derived automatically from services.cupCollector.domain in the NixOS module
NEXTAUTH_URL=https://cups.yourdomain.com

# ── PocketBase ─────────────────────────────────────────────────────────────────
# Internal URL of your PocketBase instance — NOT exposed to the browser.
# Production: derived automatically from services.cupCollector.pbPort in the NixOS module
POCKETBASE_URL=http://localhost:8090

# PocketBase superuser credentials — used server-side for admin operations
# (cup import, owned-cups writes). Never exposed to the browser.
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=replace-with-strong-password

# Household records are defined as a module option (households = [...]) in your NixOS config,
# not in this file. The init service creates them in PocketBase automatically on first boot.

# ── Google Places API ──────────────────────────────────────────────────────────
# Used ONLY in the server-side /api/nearby-starbucks route.
# NEVER expose this key to the browser or include it in client-side code.
GOOGLE_PLACES_API_KEY=your-google-places-api-key
