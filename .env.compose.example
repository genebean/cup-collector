# Cup Collector — compose stack environment variables
#
# Copy this file to .env.compose and fill in all required values:
#   cp .env.compose.example .env.compose
#
# Then build the app image with Nix, run the TLS init script, and start the stack:
#   nix build .#dockerImage && docker load < result
#   bash nginx/init-letsencrypt.sh
#   docker compose --env-file .env.compose up -d
#
# Lines marked REQUIRED must be set before the stack will start correctly.
# Lines marked OPTIONAL have a working default and can be left as-is.

# ── Domain ─────────────────────────────────────────────────────────────────────

# REQUIRED — public hostname for the app (no protocol, no trailing slash).
# nginx uses this as server_name and certbot uses it to request a certificate.
# Examples:
#   cups.example.com
DOMAIN=

# REQUIRED — email address for Let's Encrypt registration and expiry notices.
CERTBOT_EMAIL=

# ── Auth.js ────────────────────────────────────────────────────────────────────

# REQUIRED — random secret used to sign Auth.js JWTs and cookies.
# Generate a value with:  openssl rand -base64 32
AUTH_SECRET=

# REQUIRED — public URL of the Next.js app (no trailing slash).
# Used by Auth.js for OIDC callback redirect URIs.
# With nginx handling TLS this is your HTTPS domain:
#   https://cups.example.com
AUTH_URL=https://cups.example.com

# ── PocketBase ─────────────────────────────────────────────────────────────────

# OPTIONAL — internal URL used by the app container to reach PocketBase.
# Default matches the compose service name; change only if you rename the service.
POCKETBASE_URL=http://pocketbase:8090

# REQUIRED — superuser credentials for the PocketBase admin API.
# Create the initial superuser with:
#   docker compose --env-file .env.compose exec pocketbase /pb/pocketbase superuser create EMAIL PASSWORD
# Or visit http://localhost:8090/_/ on first run to create it through the UI.
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=

# OPTIONAL — IP to bind the PocketBase port on the host.
# Default (127.0.0.1) keeps it localhost-only — recommended for production.
# Set to 0.0.0.0 to expose on all interfaces (dev/debugging only).
POCKETBASE_BIND_IP=127.0.0.1

# OPTIONAL — host port for PocketBase. Default: 8090.
POCKETBASE_PORT=8090

# OPTIONAL — public hostname of PocketBase (used by Next.js image optimisation).
# Only needed if you expose PocketBase behind a public domain.
# Example: pb.example.com
POCKETBASE_HOST=

# ── PocketID OIDC ──────────────────────────────────────────────────────────────

# REQUIRED — public URL of the PocketID service (what the browser navigates to).
# Must be reachable from the user's browser for the OIDC redirect to work.
# Examples:
#   Local:       http://localhost:1411
#   Production:  https://id.example.com
POCKETID_APP_URL=http://localhost:1411

# REQUIRED — random encryption key for PocketID's database.
# Generate a value with:  openssl rand -base64 32
# WARNING: changing this after first run will break all existing sessions.
POCKETID_ENCRYPTION_KEY=

# OPTIONAL — host port for PocketID. Default: 1411.
POCKETID_PORT=1411

# OPTIONAL — set to true when PocketID is behind a reverse proxy (e.g. nginx).
# This tells PocketID to trust X-Forwarded-* headers.
POCKETID_TRUST_PROXY=false

# REQUIRED — OIDC issuer URL as seen by the Next.js app (server-side).
# Inside the compose network this is the service URL: http://pocketid:1411
# Set to the public URL if PocketID is deployed separately.
POCKETID_ISSUER_URL=http://pocketid:1411

# REQUIRED — OIDC client credentials.
# Create an OIDC application in PocketID after first-run setup:
#   1. Start the stack: docker compose --env-file .env.compose up
#   2. Visit POCKETID_APP_URL and complete the first-run setup wizard
#   3. Create a new OIDC application; set the redirect URI to:
#        AUTH_URL/api/auth/callback/pocketid
#      e.g.:  https://cups.example.com/api/auth/callback/pocketid
#   4. Copy the generated client ID and secret below
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=

# ── App image (optional) ──────────────────────────────────────────────────────

# OPTIONAL — Docker image for the Next.js app.
# Default: ghcr.io/genebean/cup-collector:latest (published by CI)
# To use a locally built image: nix build .#dockerImage && docker load < result
#   then set APP_IMAGE=cup-collector:latest
APP_IMAGE=

# ── Google Places API (optional) ───────────────────────────────────────────────

# OPTIONAL — enables the "Nearby Starbucks" map feature.
# Leave blank to disable (the rest of the app works fine without it).
# Get a key at: https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=
